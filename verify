#!/bin/bash

set -euo pipefail

typeset -r description="This script launches the program 'midas-energyNorm.Abs'"

arguments=$*
eval $(cclargs -D "" $0 "[${description}]"                                               \
  -pgm         "" "" "[path to MIDAS 'energyNorm program]"                               \
  -nml         "" "" "[path to namelist file]"                                           \
  -date        "" "" "[date of the input files]"                                         \
  -reference   "" "" "[path to reference file]"                                          \
  -states      "" "" "[path to several files on which the energy norm will be computed]" \
  -workdir     "" "" "[path to working directory prepared by 'midas.prepare_workdir']"   \
  ++ $arguments)

typeset -r energyNorm_program=${pgm}
typeset -r reference
typeset -r states
typeset -r workdir
typeset -r nml
typeset -r date

scriptName=${0##*/}

function say {
    printf "${scriptName}: ${1}\n"
    shift
    local say_message
    IFS=$'\n\t'
    for say_message in ${@}; do
        printf "\t${say_message}\n"
    done
} ## End of 'function say'

function die {
    IFS=$'\n\t'
    say $@ >&2
    exit 1
} ## End of 'function die'

if [[ ! -f "${energyNorm_program}" ]]; then
    die "The program '${energyNorm_program}' should exist and does not"
fi

for inputFile in ${reference} ${states}; do
    if [[ ! -f "${inputFile}" ]]; then
        die "The file '${inputFile}' should exist and does not"
    fi
done

mkdir ${workdir}
cd ${workdir}

if [[ -n "${nml}" ]]; then
    if [[ -f "${nml}" ]]; then
        say "Importing the namelist ${nml} in the working directory"
        cp ${nml} flnml
    else
        die "The namelist given with option '-nml', ${nml}, does not exist."
    fi
fi

npex=5
npey=4

cat > ptopo_nml <<EOF
 &ptopo
  npex=${npex}
  npey=${npey}
/
EOF

cat > inputFiles <<EOF
## reference file
${reference}

## file containing the states which energy norm will be computed
EOF
for stateFile in $(echo ${states} | tr ' '  '\n'); do
    echo ${stateFile} >> inputFiles
done

ulimit -c unlimited

export TMG_ON=YES
export OMP_STACKSIZE=4G
#export OMP_NUM_THREADS=${omp_num_threads}

export MIDAS_DATE=${date}

## When FOR_DUMP_CORE_FILE=1 and the code abort on runtime error, cores
## will be dumped in the work directory; one per process.
## Each core can weight O(10) Gb (times the number of processes)
export FOR_DUMP_CORE_FILE=

say "Start of ${energyNorm_program} at $(date +%Y%m%d:%H:%M:%S.%N)"
say "The listing will be available in the file ${PWD}/listing"

SECONDS=0

mpirun -n $((npex*npey)) ${energyNorm_program} > listing

say "End of ${energyNorm_program} in ${SECONDS} seconds at $(date +%Y%m%d:%H:%M:%S.%N)"

## Parse the output file 'energyNorm_ascii' to detect if tests pass or not
energyNorm_output=energyNorm_ascii
energyNorm_threshold=1.0

say "Verifying the results from the file ${PWD}/${energyNorm_output}"

processLine=false
someFailed=false
typeset -a resultMessages
while read -u3 line; do
    if [[ "${line}" =~ ^fileName ]]; then
        processLine=true
    elif [[ "${processLine}" = true ]]; then
        fileName=$(echo ${line} | awk '{print $1}')
        totalEnergy=$(echo ${line} | awk '{print $2}')

        if (( $(echo "${totalEnergy} > ${energyNorm_threshold}" |bc -l) )); then
            result=FAIL
            someFailed=true
        else
            result=pass
        fi

        resultMessages+=("${result} for ${fileName} (${totalEnergy} vs ${energyNorm_threshold})")
    fi
done 3< ${energyNorm_output}

say "Here are the evaluations:" "${resultMessages[@]}"

if [[ "${processLine}" = false ]]; then
    die "Something wrong happened while processing ${PWD}/${energyNorm_output}"
else
    if [[ "${someFailed}" = true ]]; then
        say "The results have been verified and some failed!"
    else
        say "The results have been verified and they all pass successfully!"
    fi
fi
