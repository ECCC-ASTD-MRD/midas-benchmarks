#!/bin/bash

set -euo pipefail

stats=${1:-mean} ## or 'rms'
npex=${2:-4}
npey=${3:-5}
omp_num_threads=${4:-4}

scripts_directory=midas/tools/midas_scripts

midas_version=v_4.0.2-21-g4b42809
energyNorm_program=${PWD}/midas/compiledir/midas_abs/midas-energyNorm_${ORDENV_PLAT}-${midas_version}.Abs

date=2024091900
namelist=${PWD}/midas/maestro/suites/midas_system_tests/config/Tests/energyNorm/anal${stats}/nml
reference=${PWD}/work/10km_48x52/${date}_000_analmean
states="${PWD}/work/10km_44x52/${date}_000_anal${stats} ${PWD}/work/10km_debug_48x52/${date}_000_anal${stats} ${PWD}/work/10km_flipobs_x_48x52-20241004/${date}_000_anal${stats} ${PWD}/work/10km_flipobs_xy_48x52/${date}_000_anal${stats} ${PWD}/work/10km_flipobs_y_48x52/${date}_000_anal${stats} ${PWD}/work/10km_O1_48x52/${date}_000_anal${stats} ${PWD}/work/10km_O2_48x52/${date}_000_anal${stats} ${PWD}/work/10km_O3_48x52/${date}_000_anal${stats}"

workdir=${PWD}/work/verify-${stats}
[[ -d "${workdir}" ]] && rm -r ${workdir}

${scripts_directory}/midas.energyNorm -pgm ${energyNorm_program} -nml ${namelist}   \
                    -reference ${reference} -states ${states} -workdir ${workdir}   \
                    -npex ${npex} -npey ${npey} -omp_num_threads ${omp_num_threads} \
                    -date ${date}
