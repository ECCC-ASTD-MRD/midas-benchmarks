#!/bin/bash

set -euo pipefail

npex=${1:-4}
npey=${2:-5}
omp_num_threads=${3:-4}

scripts_directory=midas/tools/midas_scripts

midas_version=v_4.0.2-21-g4b42809
energyNorm_program=${PWD}/midas/compiledir/midas_abs/midas-energyNorm_${ORDENV_PLAT}-${midas_version}.Abs

date=2024091900
namelist=${PWD}/midas/maestro/suites/midas_system_tests/config/Tests/energyNorm/analmean/nml
reference=${PWD}/work/10km_48x52/${date}_000_analmean
states="${PWD}/work/10km_44x52/${date}_000_analmean ${PWD}/work/10km_debug_48x52/${date}_000_analmean ${PWD}/work/10km_flipobs_x_48x52/${date}_000_analmean ${PWD}/work/10km_flipobs_xy_48x52/${date}_000_analmean ${PWD}/work/10km_flipobs_y_48x52/${date}_000_analmean ${PWD}/work/10km_O1_48x52/${date}_000_analmean ${PWD}/work/10km_O2_48x52/${date}_000_analmean ${PWD}/work/10km_O3_48x52/${date}_000_analmean"

workdir=${PWD}/work/verify
[[ -d "${workdir}" ]] && rm -r ${workdir}

${scripts_directory}/midas.energyNorm -pgm ${energyNorm_program} -nml ${namelist}   \
                    -reference ${reference} -states ${states} -workdir ${workdir}   \
                    -npex ${npex} -npey ${npey} -omp_num_threads ${omp_num_threads} \
                    -date ${date}
