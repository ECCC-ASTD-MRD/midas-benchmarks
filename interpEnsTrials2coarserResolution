#!/bin/bash

## One can submit this script directly in batch using the command:
##    resolution=100km
##    ord_soumet interpEnsTrials2coarserResolution -mach ppp6 -cpus 80 -m 180G -listing ${PWD} -w 180 -jn interpEnsTrials_${resolution} \
##                               -args ${resolution} ${PWD}/work/ensemble ${PWD}/work/ensemble_${resolution}

set -ueo pipefail

resolution=${1:?"interpEnsTrials2coarserResolution: The resolution must be the first argument."}
ensTrialsInputDir=${2:?"interpEnsTrials2coarserResolution: You must specify a second argument which is a directory containing to files to process."}
ensTrialsOutputDir=${3:?"interpEnsTrials2coarserResolution: You must specify a third argument which is a directory where the files processed will be stored."}

INTERPENSTRIALS_THREADS=${INTERPENSTRIALS_THREADS:-${OMP_NUM_THREADS:-1}}
INTERPENSTRIALS_TMPDIR=${INTERPENSTRIALS_TMPDIR:-}

set +ux
which pgsm > /dev/null 2>&1 || . r.load.dot eccc/mrd/rpn/utils/20251009-beta
set -u

interpolateFile () {
    typeset -r inputFile=${1:?"interpEnsTrials2coarserResolution.interpolateFile: You must specify an input file"}
    typeset -r outputDir=${2:?"interpEnsTrials2coarserResolution.interpolateFile: You must specify an output director"}
    typeset -r gridDirective=${3:?"interpEnsTrials2coarserResolution.interpolateFile: The destination grid as a PGSM directive"}
    typeset -r targetGrid=${4:-}

    typeset -r outputFileFinal=${ensTrialsOutputDir}/$(basename ${inputFile})
    [ -f "${outputFileFinal}" ] && rm ${outputFileFinal}

    if [[ -n "${INTERPENSTRIALS_TMPDIR}" ]]; then
        typeset -r outputFile=${INTERPENSTRIALS_TMPDIR}/$(basename ${inputFile})
        [ -f "${outputFile}" ] && rm ${outputFile}
    else
        typeset -r outputFile=${outputFileFinal}
    fi

    export FST_OPTIONS="BACKEND=RSF"
    pgsm -iment ${inputFile} ${targetGrid} -ozsrt ${outputFile} -msglvl error -i <<EOF
 SORTIE(STD,1000,A)
 ${gridDirective}
 COMPAC=-16
 compress=oui
 HEURE(tout)
 SETINTX(LINEAIR)
 CHAMP('UV',TOUT)
 CHAMP('TT',TOUT)
 CHAMP('HU',TOUT)
 CHAMP('GZ',TOUT)
 CHAMP('P0',TOUT)
 CHAMP('TG',TOUT)
EOF

    if [[ -n "${INTERPENSTRIALS_TMPDIR}" ]]; then
        cp ${outputFile} ${outputFileFinal}
        rm ${outputFile}
    fi

    ls -ahl ${inputFile} ${outputFileFinal}
} ## End of routine 'interpolateFile'

targetGrid=
if [ "${resolution}" = 100km ]; then
    gridDirective="GRILLE(GAUSS,400,200,GLOBAL)"
elif [ "${resolution}" = 50km ]; then
    gridDirective="GRILLE(GAUSS,800,400,GLOBAL)"
elif [ "${resolution}" = 35km ]; then
    gridDirective="GRILLE(GAUSS,1080,540,GLOBAL)"
elif [ -f "${resolution}" ]; then
    ## If '${resolution}' is a file, then we assume that it is the target grid
    gridDirective="GRILLE(COMME,fentree,'P0',-1,-1,-1,-1,-1,'TARGETGRID')"
    targetGrid=${resolution}
else
    echo "interpEnsTrials2coarserResolution: The resolution must be one of supported resolution: 100km, 50km and 35km.  We got '${resolution}'." >&2
    exit 1
fi

[ ! -d "${ensTrialsOutputDir}" ] && mkdir -p ${ensTrialsOutputDir}

let concurrentEncodings=1
for inputFile in ${ensTrialsInputDir}/*; do
    interpolateFile ${inputFile} ${ensTrialsOutputDir} ${gridDirective} ${targetGrid} &
    if (( concurrentEncodings == INTERPENSTRIALS_THREADS )); then
        ## Wait for all the concurrent threads to complete
        time wait
        let concurrentEncodings=0 || true
    fi
    let concurrentEncodings=concurrentEncodings+1
done

## Wait for any leftovers
time wait
