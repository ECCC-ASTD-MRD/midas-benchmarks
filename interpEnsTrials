#!/bin/bash

set -euo pipefail

typeset -r description="This script launches the program 'midas-ensPostProcess.Abs' to interpolation the ensemble trials"

arguments=$*
eval $(cclargs -D "" $0 "[${description}]"                         \
  -pgm         "" "" "[path to MIDAS 'ensPostProcess' program]"    \
  -nml         "" "" "[path to namelist file]"                     \
  -npex        5  5  "[number of MPI ranks in the x direction]"    \
  -npey        4  4  "[number of MPI ranks in the y direction]"    \
  -targetGrid  "" "" "[path to the definition of the target grid]" \
  -gzSfc       "" "" "[path to a RSF file containing the surface GZ]" \
  -ctlmem      "" "" "[path to the control member at same resolution as 'targetGrid']" \
  -ensInput    "" "" "[path to input ensemble trials]"             \
  -ensOutput   "" "" "[path to interpolated ensemble trials]"      \
  -workdir     "" "" "[path to working directory]"                 \
  ++ $arguments)

typeset -r ensPostProcess_program=${pgm}
typeset -r nml
typeset -r targetGrid
typeset -r ensInput
typeset -r gzSfc
typeset -r ctlmem
typeset -r ensOutput
typeset -r workdir

scriptName=${0##*/}

function say {
    printf "${scriptName}: ${1}\n"
    shift
    local say_message
    IFS=$'\n\t'
    for say_message in ${@}; do
        printf "\t${say_message}\n"
    done
} ## End of 'function say'

function die {
    IFS=$'\n\t'
    say $@ >&2
    exit 1
} ## End of 'function die'

if [[ ! -f "${ensPostProcess_program}" ]]; then
    die "The program '${ensPostProcess_program}' should exist and does not"
fi

if [[ ! -d "${ensInput}" ]]; then
    die "The directory '${ensInput}' should exist and does not"
fi

if [[ -d "${ensOutput}" ]]; then
    die "The directory '${ensOutput}' should not exist and does"
fi

mkdir ${workdir}
cd ${workdir}

if [[ -n "${nml}" ]]; then
    if [[ -f "${nml}" ]]; then
        say "Importing the namelist ${nml} in the working directory"
        cp ${nml} flnml
    else
        die "The namelist given with option '-nml', ${nml}, does not exist."
    fi
fi

cat > ptopo_nml <<EOF
 &ptopo
  npex=${npex}
  npey=${npey}
/
EOF

ln -s ${ensInput} ensemble_trial
ln -s ${targetGrid} targetgrid

ulimit -c unlimited

export TMG_ON=YES
export OMP_STACKSIZE=4G

## Needed to output files in the expected format
export FST_OPTIONS="BACKEND=RSF"

say "Start of ${ensPostProcess_program} at $(date +%Y%m%d:%H:%M:%S.%N)"
say "The listing will be available in the file ${PWD}/listing"

SECONDS=0

mpirun -n $((npex*npey)) ${ensPostProcess_program} > listing

say "End of ${ensPostProcess_program} in ${SECONDS} seconds at $(date +%Y%m%d:%H:%M:%S.%N)"

if [[ -n "${gzSfc}" ]]; then
    typeset -r firstMember=*_006_0001
    say "Adding surface GZ to first member ${firstMember}"
    cat ${gzSfc} >> ${firstMember}
fi

say "Moving the output files from ${workdir} to ${ensOutput}"
mkdir -p   ${ensOutput}
mv *_006_* ${ensOutput}

if [[ -n "${ctlmem}" ]]; then
    say "Copying the control member ${ctlmem} to ${ensOutput}"
    cp ${ctlmem} ${ensOutput}
fi

say "You can find the interpolated ensemble trials in the directory ${ensOutput}"
